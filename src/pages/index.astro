    <!-- ===== JAVASCRIPT: Category Filter + Mobile Menu ===== -->
    <script is:inline>
        // ===== Mobile Menu Toggle =====
        const mobileBtn = document.getElementById('mobile-menu-button');
        const mobileMenu = document.getElementById('mobile-menu');
        mobileBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
        mobileMenu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => mobileMenu.classList.add('hidden'));
        });

        // ===== Dynamic Category Filter =====
        const filterBtns = document.querySelectorAll('.filter-btn');
        const newsCards = document.querySelectorAll('.news-card');
        const resultCount = document.getElementById('result-count');
        const emptyState = document.getElementById('empty-state');
        const newsGrid = document.getElementById('news-grid');

        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const category = btn.dataset.category;

                // Update active state on buttons
                filterBtns.forEach(b => {
                    b.classList.remove('active', 'bg-gradient-to-r', 'from-brand-500', 'to-futuristic-accent', 'text-white', 'border-transparent', 'shadow-lg', 'shadow-brand-500/20');
                    b.classList.add('bg-slate-900/80', 'text-slate-400', 'border-slate-800');
                    // Reset count badge
                    const badge = b.querySelector('.filter-count-badge');
                    if (badge) {
                        badge.classList.remove('bg-white/20', 'text-white');
                        badge.classList.add('bg-slate-800', 'text-slate-400');
                    }
                });
                btn.classList.add('active');
                btn.classList.remove('bg-slate-900/80', 'text-slate-400', 'border-slate-800');
                btn.classList.add('bg-gradient-to-r', 'from-brand-500', 'to-futuristic-accent', 'text-white', 'border-transparent', 'shadow-lg', 'shadow-brand-500/20');
                const activeBadge = btn.querySelector('.filter-count-badge');
                if (activeBadge) {
                    activeBadge.classList.remove('bg-slate-800', 'text-slate-400');
                    activeBadge.classList.add('bg-white/20', 'text-white');
                }

                // Filter cards with animation
                let visibleCount = 0;
                newsCards.forEach((card, index) => {
                    const cardCategories = card.dataset.categories.split(',');
                    const shouldShow = cardCategories.includes(category);

                    if (shouldShow) {
                        visibleCount++;
                        card.classList.remove('hiding');
                        card.classList.add('showing');
                        card.style.display = '';
                        // Staggered animation
                        card.style.animationDelay = `${visibleCount * 0.06}s`;
                        // Force re-trigger animation
                        card.style.animation = 'none';
                        card.offsetHeight; // trigger reflow
                        card.style.animation = '';
                    } else {
                        card.classList.add('hiding');
                        card.classList.remove('showing');
                        // Delay hiding for smooth animation
                        setTimeout(() => {
                            if (card.classList.contains('hiding')) {
                                card.style.display = 'none';
                            }
                        }, 350);
                    }
                });

                // Update result counter
                resultCount.textContent = visibleCount;

                // Show/hide empty state
                if (visibleCount === 0) {
                    emptyState.classList.remove('hidden');
                    newsGrid.classList.add('hidden');
                } else {
                    emptyState.classList.add('hidden');
                    newsGrid.classList.remove('hidden');
                }
            });
        });
    </script>
</body>
