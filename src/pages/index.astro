                                    </span>
                                )}
                                <div class={`rounded-2xl bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-white shadow-2xl group-hover:scale-110 group-hover:rotate-3 transition-transform duration-500 ${isFirst ? 'w-20 h-20 sm:w-24 sm:h-24 text-4xl sm:text-5xl' : 'w-16 h-16 sm:w-18 sm:h-18 text-3xl sm:text-4xl'}`}>
