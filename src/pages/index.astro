                    const delay = (idx * 0.05).toFixed(2);

                    return (
                        <article
                            class={`news-card card-shimmer showing card-enter rounded-3xl overflow-hidden bg-dark-800/70 border border-white/5 ${details.hoverBorder} flex flex-col group ${isFirst ? 'xl:col-span-2 xl:row-span-1' : ''}`}
