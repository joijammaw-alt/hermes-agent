---
// index.astro - หน้าหลักโฉมใหม่ระดับ Ultra-Premium ของโรงเรียนวัชระ (Watchara School)
// ออกแบบและพัฒนาโดย Hermes AI Assistant
// ดีไซน์ระดับ Premium ด้วย Dynamic Cards Grid + Category Filter

import { getCollection } from 'astro:content';
import { frontmatter as landingFrontmatter, rawContent } from './landing.md';

const raw = rawContent();
const lines = raw.split('\n').map(l => l.trim()).filter(Boolean);
const slogan = lines.find(l => l.startsWith("สถาบันการศึกษาชั้นนำ")) || "มุ่งมั่นสู่ความเป็นเลิศ พัฒนาคุณธรรม นำเทคโนโลยีสู่อนาคต";

const schoolInfo = {
  name: "โรงเรียนวัชระ",
  englishName: "Watchara School",
  slogan: slogan,
  vision: "สร้างสรรค์ปัญญา พัฒนาคุณธรรม นำเทคโนโลยี สรรค์สร้างนวัตกรรมสู่สากล",
  missions: [
    "จัดการเรียนการสอนที่เน้นผู้เรียนเป็นสำคัญ และส่งเสริมความเป็นเลิศทางวิชาการ",
    "บูรณาการเทคโนโลยีและนวัตกรรมในการเรียนรู้ทุกระดับชั้น",
    "ปลูกฝังคุณธรรม จริยธรรม และค่านิยมอันดีงามของไทย",
    "พัฒนาทักษะชีวิตและทักษะแห่งศตวรรษที่ 21 ให้กับผู้เรียน"
  ],
  address: "123 ถนนวิทยพัฒนา ตำบลในเมือง อำเภอเมือง จังหวัดนครสวรรค์ 60000",
  phone: "056-123456",
  email: "info@watchara.ac.th"
};

// ดึงข้อมูลข่าวสารทั้งหมดจาก Content Collections
const blogEntries = await getCollection('blog');

// === ข้อมูลข่าวสารทั้ง 6 รายการ จาก Content Collections ===
const allNews = blogEntries.map((entry, index) => {
  const data = entry.data;
  const categories = ["all"];
  let categoryLabel = "ข่าวเด่น";
  let icon = "fa-graduation-cap";
  let gradient = "from-sky-500 via-blue-600 to-indigo-700";
  let badgeColor = "bg-sky-500";
  let featured = false;
  
  const titleLower = data.title.toLowerCase();
  if (titleLower.includes("หุ่นยนต์") || titleLower.includes("ai") || titleLower.includes("center") || titleLower.includes("lab")) {
    categories.push("technology");
    categoryLabel = "เทคโนโลยี";
    icon = "fa-robot";
    gradient = "from-blue-600 via-indigo-600 to-violet-700";
    badgeColor = "bg-blue-600";
  } else if (titleLower.includes("วิชาการ") || titleLower.includes("แข่งขัน")) {
    categories.push("academic");
    categoryLabel = "วิชาการ";
    icon = "fa-trophy";
    gradient = "from-amber-500 via-orange-500 to-red-500";
    badgeColor = "bg-amber-500";
  } else if (titleLower.includes("ทัศนศึกษา") || titleLower.includes("ประวัติศาสตร์")) {
    categories.push("activity");
    categoryLabel = "กิจกรรม";
    icon = "fa-landmark";
    gradient = "from-emerald-500 via-teal-500 to-cyan-600";
    badgeColor = "bg-emerald-500";
  } else if (titleLower.includes("หลักสูตร") || titleLower.includes("เขียนโปรแกรม")) {
    categories.push("curriculum");
    categoryLabel = "หลักสูตร";
    icon = "fa-code";
    gradient = "from-purple-500 via-violet-600 to-fuchsia-600";
    badgeColor = "bg-purple-500";
  } else if (titleLower.includes("สัมมนา") || titleLower.includes("ผู้ปกครอง")) {
    categories.push("parents");
    categoryLabel = "ผู้ปกครอง";
    icon = "fa-users";
    gradient = "from-rose-500 via-pink-500 to-red-500";
    badgeColor = "bg-rose-500";
  }
  
  // ให้สองข่าวแรกสุดหรือข่าวเฉพาะเป็นข่าวเด่น
  if (index === 0 || index === 1 || data.title.includes("ต้อนรับ") || data.title.includes("หุ่นยนต์และ AI")) {
    categories.push("featured");
    featured = true;
  }
  
  // ดึงสรุปย่อของบทความ
  const bodyText = entry.body || "";
  const cleanedBody = bodyText
    .replace(/#+\s+.+/g, "") // ลบหัวข้อ
    .replace(/[#\n\*_-]/g, " ") // ลบสัญลักษณ์ Markdown
    .trim();
  const summary = cleanedBody ? cleanedBody.substring(0, 180) + "..." : "อ่านรายละเอียดเพิ่มเติมของข่าวสารนี้เพื่อติดตามข้อมูลและกิจกรรมจากทางโรงเรียน...";

  return {
    id: index,
    title: data.title,
    date: data.date ? new Date(data.date).toISOString().split('T')[0] : "2026-05-27",
    author: data.source || "ฝ่ายประชาสัมพันธ์",
    categories,
    categoryLabel,
    summary,
    icon,
    gradient,
    badgeColor,
    featured
  };
}).sort((a, b) => b.date.localeCompare(a.date));

// === หมวดหมู่สำหรับการกรอง ===
const categories = [
  { key: "all", label: "ทั้งหมด", icon: "fa-layer-group", count: allNews.length },
  { key: "featured", label: "ข่าวเด่น", icon: "fa-star", count: allNews.filter(n => n.categories.includes("featured")).length },
  { key: "technology", label: "เทคโนโลยี", icon: "fa-microchip", count: allNews.filter(n => n.categories.includes("technology")).length },
  { key: "academic", label: "วิชาการ", icon: "fa-flask", count: allNews.filter(n => n.categories.includes("academic")).length },
  { key: "activity", label: "กิจกรรม", icon: "fa-route", count: allNews.filter(n => n.categories.includes("activity")).length },
  { key: "curriculum", label: "หลักสูตร", icon: "fa-book-open", count: allNews.filter(n => n.categories.includes("curriculum")).length },
  { key: "parents", label: "ผู้ปกครอง", icon: "fa-people-roof", count: allNews.filter(n => n.categories.includes("parents")).length }
];
---

<html lang="th" class="scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{schoolInfo.name} | {schoolInfo.englishName} — มุ่งสู่อนาคตด้วยนวัตกรรมการศึกษา</title>
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700;800&family=Sarabun:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Sarabun', 'sans-serif'],
                        heading: ['Kanit', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f0f7ff',
                            100: '#e0effe',
                            200: '#bae0fd',
                            300: '#7cc8fc',
                            400: '#38b0f8',
                            500: '#0ea5e9',
                            600: '#0284c7',
                            700: '#0369a1',
                            800: '#075985',
                            900: '#0c4a6e',
                            950: '#082f49',
                        },
                        futuristic: {
                            dark: '#030712',
                            card: '#111827',
                            border: '#1f2937',
                            accent: '#6366f1',
                            neon: '#10b981',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        h1, h2, h3, h4, h5, h6 { font-family: 'Kanit', sans-serif; }
        .glass-nav {
            background: rgba(3, 7, 18, 0.75);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
        }
        .futuristic-gradient {
            background: radial-gradient(circle at top, #0f172a 0%, #030712 100%);
        }
        .gradient-text {
            background: linear-gradient(135deg, #38b0f8 0%, #6366f1 50%, #ec4899 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .animate-float {
            animation: float 6s ease-in-out infinite;
        }
        .animate-float-delayed {
            animation: float 6s ease-in-out infinite;
            animation-delay: 3s;
        }
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
        @keyframes fadeSlideUp {
            from { opacity: 0; transform: translateY(30px) scale(0.97); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        @keyframes countUp {
            from { opacity: 0; transform: scale(0.5); }
            to { opacity: 1; transform: scale(1); }
        }
        .news-card {
            animation: fadeSlideUp 0.5s ease-out both;
        }
        .news-card:nth-child(1) { animation-delay: 0.05s; }
        .news-card:nth-child(2) { animation-delay: 0.1s; }
        .news-card:nth-child(3) { animation-delay: 0.15s; }
        .news-card:nth-child(4) { animation-delay: 0.2s; }
        .news-card:nth-child(5) { animation-delay: 0.25s; }
        .news-card:nth-child(6) { animation-delay: 0.3s; }
        .news-card.hiding {
            opacity: 0;
            transform: scale(0.92) translateY(10px);
            pointer-events: none;
            position: absolute;
            visibility: hidden;
        }
        .news-card.showing {
            opacity: 1;
            transform: scale(1) translateY(0);
            position: relative;
            visibility: visible;
        }
        .filter-btn.active {
            background: linear-gradient(135deg, #0ea5e9, #6366f1);
            color: white;
            box-shadow: 0 4px 20px rgba(14, 165, 233, 0.3);
            border-color: transparent;
        }
        .filter-count-badge {
            animation: countUp 0.3s ease-out;
        }
        .card-shine {
            position: relative;
            overflow: hidden;
        }
        .card-shine::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.03), transparent);
            transition: left 0.6s ease;
            z-index: 1;
        }
        .card-shine:hover::before {
            left: 100%;
        }
        .pulse-dot {
            animation: pulseDot 2s ease-in-out infinite;
        }
        @keyframes pulseDot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(1.5); }
        }
    </style>
</head>
