            <aside class="lg:col-span-4 space-y-8">
                
                {/* School Banner Card */}
                <div class="bg-gradient-to-br from-dark-800 to-dark-900 border border-white/5 rounded-3xl p-6 relative overflow-hidden group">
                    <div class="absolute inset-0 bg-gradient-to-tr from-brand-500/10 via-purple-500/5 to-transparent blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                    <div class="relative z-10 text-center space-y-4">
                        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-500 via-purple-500 to-pink-500 flex items-center justify-center text-white text-3xl shadow-xl shadow-brand-500/20 mx-auto">
                            <i class="fa-solid fa-graduation-cap"></i>
                        </div>
                        <div>
                            <h3 class="text-xl font-extrabold text-white font-heading">โรงเรียนวัชระ</h3>
                            <p class="text-[10px] text-brand-400 font-bold uppercase tracking-[0.2em]">Watchara School</p>
                        </div>
                        <p class="text-xs text-slate-400 leading-relaxed">มุ่งมั่นพัฒนาผู้เรียนสู่นวัตกรรมแห่งอนาคตและคุณธรรมอันเป็นเลิศ</p>
                        <a href="/#contact" class="inline-flex items-center justify-center w-full py-3 text-xs font-bold text-white bg-gradient-to-r from-brand-500 to-purple-600 rounded-xl hover:shadow-lg hover:shadow-brand-500/25 transition-all">
                            <i class="fa-solid fa-paper-plane mr-2 text-[10px]"></i> สมัครเรียน / ติดต่อเรา
                        </a>
                    </div>
                </div>

                {/* Recent / Related News List */}
                <div class="space-y-4">
                    <h3 class="text-base font-extrabold text-white font-heading tracking-wide uppercase flex items-center gap-2">
                        <span class="w-1.5 h-4 bg-brand-500 rounded-full"></span> ข่าวสารอื่นๆ ล่าสุด
                    </h3>
                    <div class="space-y-4">
                        {recentPosts.length === 0 ? (
                            <p class="text-xs text-slate-500 italic">ไม่มีข่าวสารอื่นในช่วงนี้</p>
                        ) : (
                            recentPosts.map((rPost) => {
                                const rCats = getCategories(rPost);
                                const rDetails = getCategoryDetails(rCats);
                                return (
                                    <a href={`/news/${rPost.slug ? decodeURIComponent(rPost.slug) : String(rPost.id)}`} class="block sidebar-card bg-dark-800/40 border border-white/5 hover:border-white/10 rounded-2xl p-4 flex gap-4">
                                        <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${rDetails.gradient} flex items-center justify-center text-white text-lg flex-shrink-0`}>
                                            <i class={rDetails.icon}></i>
                                        </div>
                                        <div class="space-y-1 min-w-0 flex-1">
                                            <div class="flex items-center justify-between text-[10px] text-slate-500">
                                                <span class="font-bold text-brand-400/80">{rDetails.label}</span>
                                                <span>{formatDate(rPost.date)}</span>
                                            </div>
                                            <h4 class="text-xs sm:text-sm font-bold text-white leading-snug truncate" set:html={rPost.title?.rendered} />
                                        </div>
                                    </a>
                                );
                            })
                        )}
                    </div>
                </div>

            </aside>

        </div>
    </main>

    <!-- ======== FOOTER ======== -->
    <footer class="bg-dark-900 border-t border-white/5 py-8 text-center text-xs text-slate-500 relative z-10">
        <div class="max-w-7xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-4">
            <p>&copy; 2026 Watchara School. All rights reserved.</p>
            <p class="flex items-center gap-1.5">Designed with <i class="fa-solid fa-heart text-rose-500 text-[10px]"></i> by <span class="text-brand-400 font-bold">Hermes AI</span></p>
        </div>
    </footer>

</body>
</html>
