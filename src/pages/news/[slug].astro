// src/pages/news/[slug].astro
export async function getStaticPaths() {
  const wpUrl = import.meta.env.WP_URL || process.env.WP_URL || 'https://wordpress.blayblay.com';
  const wpUser = import.meta.env.WP_USER || process.env.WP_USER || 'Bank';
  const wpPass = import.meta.env.WP_PASS || process.env.WP_PASS || 'XJeJ nPIz iSZn vkhw UpNd 9odZ';

  let posts = [];
  try {
    const headers = {};
    if (wpUser && wpPass) {
      headers['Authorization'] = 'Basic ' + btoa(`${wpUser}:${wpPass}`);
    }
    
    // Fetch posts from WordPress API
    const response = await fetch(`${wpUrl.replace(/\/$/, '')}/wp-json/wp/v2/posts?per_page=100&_embed`, { headers });
    
    if (response.ok) {
      posts = await response.json();
    } else {
      console.error(`WordPress API in getStaticPaths returned status ${response.status}`);
    }
  } catch (e) {
    console.error("Failed to fetch from WordPress API for getStaticPaths:", e);
  }

  // Generate paths for each post using its WordPress slug
  return posts.map((post) => ({
    params: { slug: post.slug ? decodeURIComponent(post.slug) : String(post.id) },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;

// Helpers (Consistent with index.astro)
const getCategories = (post) => {
  const cats = ['all'];
  let title = post.title?.rendered || '';
  if (typeof title === 'string') {
    title = title
      .replace(/&#8211;/g, '–')
      .replace(/&amp;/g, '&')
      .replace(/&lt;/g, '<')
      .replace(/&gt;/g, '>')
      .replace(/&quot;/g, '"')
      .replace(/&#039;/g, "'");
  }
  const tags = post.tags || [];

  if (title.includes('หุ่นยนต์') || title.includes('AI') || title.includes('เทคโนโลยี') || title.includes('เขียนโปรแกรม') || title.includes('Coding') || tags.includes('เทคโนโลยี')) { cats.push('technology'); }
  if (title.includes('แข่งขัน') || title.includes('รางวัล') || title.includes('วิชาการ') || title.includes('เรียน') || title.includes('O-NET') || title.includes('สอบ') || tags.includes('วิชาการ')) { cats.push('academic'); }
  if (title.includes('ทัศนศึกษา') || title.includes('กิจกรรม') || title.includes('แคมป์') || title.includes('ค่าย') || title.includes('สัมมนา') || title.includes('สันทนาการ') || tags.includes('กิจกรรม')) { cats.push('activity'); }
  if (title.includes('หลักสูตร') || title.includes('การสอน') || title.includes('Core') || title.includes('English') || title.includes('วิทยาศาสตร์') || title.includes('คอมพิวเตอร์') || tags.includes('หลักสูตร')) { cats.push('curriculum'); }
  if (title.includes('ผู้ปกครอง') || title.includes('เลี้ยงดู') || title.includes('RACI') || title.includes('สัมพันธ์') || title.includes('PTA') || tags.includes('ผู้ปกครอง')) { cats.push('parents'); }
  if (title.includes('การศึกษา') || title.includes('ครู') || title.includes('นโยบาย') || title.includes('สลช') || title.includes('โรงเรียน') || title.includes('มช.') || title.includes('มหาวิทยาลัย') || title.includes('ผู้บริหาร') || title.includes('วิจัย') || tags.includes('การศึกษา') || tags.includes('นโยบาย')) { cats.push('education'); }
  if (title.includes('เปิดตัว') || title.includes('แข่งขัน') || title.includes('นโยบาย') || title.includes('มช.') || title.includes('ผู้บริหาร') || title.includes('RACI') || cats.length <= 2) { cats.push('featured'); }

  return [...new Set(cats)];
};

const getCategoryDetails = (cats) => {
  if (cats.includes('technology')) {
    return { gradient: 'from-blue-600 via-indigo-600 to-violet-700', hoverBorder: 'hover:border-blue-500/30', icon: 'fa-solid fa-robot', label: 'เทคโนโลยี', textColor: 'group-hover:text-blue-400', btnColor: 'text-blue-400 hover:text-blue-300', glow: 'bg-blue-500', accent: 'blue' };
  }
  if (cats.includes('academic')) {
    return { gradient: 'from-amber-500 via-orange-500 to-red-500', hoverBorder: 'hover:border-amber-500/30', icon: 'fa-solid fa-trophy', label: 'วิชาการ', textColor: 'group-hover:text-amber-400', btnColor: 'text-amber-400 hover:text-amber-300', glow: 'bg-amber-500', accent: 'amber' };
  }
  if (cats.includes('activity')) {
    return { gradient: 'from-emerald-500 via-teal-500 to-cyan-600', hoverBorder: 'hover:border-emerald-500/30', icon: 'fa-solid fa-route', label: 'กิจกรรม', textColor: 'group-hover:text-emerald-400', btnColor: 'text-emerald-400 hover:text-emerald-300', glow: 'bg-emerald-500', accent: 'emerald' };
  }
  if (cats.includes('curriculum')) {
    return { gradient: 'from-purple-500 via-violet-600 to-fuchsia-600', hoverBorder: 'hover:border-purple-500/30', icon: 'fa-solid fa-book-open', label: 'หลักสูตร', textColor: 'group-hover:text-purple-400', btnColor: 'text-purple-400 hover:text-purple-300', glow: 'bg-purple-500', accent: 'purple' };
  }
  if (cats.includes('parents')) {
    return { gradient: 'from-rose-500 via-pink-500 to-red-500', hoverBorder: 'hover:border-rose-500/30', icon: 'fa-solid fa-people-roof', label: 'ผู้ปกครอง', textColor: 'group-hover:text-rose-400', btnColor: 'text-rose-400 hover:text-rose-300', glow: 'bg-rose-500', accent: 'rose' };
  }
  if (cats.includes('education')) {
    return { gradient: 'from-cyan-500 via-sky-600 to-blue-700', hoverBorder: 'hover:border-sky-500/30', icon: 'fa-solid fa-building-columns', label: 'การศึกษา', textColor: 'group-hover:text-sky-400', btnColor: 'text-sky-400 hover:text-sky-300', glow: 'bg-sky-500', accent: 'sky' };
  }
  return { gradient: 'from-slate-500 via-gray-600 to-zinc-700', hoverBorder: 'hover:border-slate-500/30', icon: 'fa-solid fa-newspaper', label: 'ทั่วไป', textColor: 'group-hover:text-slate-400', btnColor: 'text-slate-400 hover:text-slate-300', glow: 'bg-slate-500', accent: 'slate' };
};

const formatDate = (date) => {
  try {
    const d = new Date(date);
    const thMonth = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
    return `${d.getDate()} ${thMonth[d.getMonth()]} ${d.getFullYear() + 543}`;
  } catch { return '28 พ.ค. 2569'; }
};

const postCategories = getCategories(post);
const categoryDetails = getCategoryDetails(postCategories);

// Find other recent posts for the sidebar (excluding current)
const recentPosts = allPosts
  .filter(p => p.id !== post.id)
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf())
  .slice(0, 4);
